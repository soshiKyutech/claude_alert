# claude_alert ntfy.sh configuration
# Copy this file to ~/.config/claude_alert/config and fill in values.

# Required: your ntfy topic (use a random, hard-to-guess string)
# CLAUDE_ALERT_NTFY_TOPIC="your-random-topic-here"

# Optional: ntfy server (defaults to https://ntfy.sh)
# CLAUDE_ALERT_NTFY_SERVER="https://ntfy.sh"

# Optional: access token for private topics
# CLAUDE_ALERT_NTFY_TOKEN=""
